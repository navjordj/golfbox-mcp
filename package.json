{
  "name": "golfbox-mcp",
  "version": "0.1.0",
  "description": "MCP server scaffold for agent-safe GolfBox tee-time workflows.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "golfbox-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun src/index.ts",
    "start": "node dist/index.js",
    "build:private-release": "node scripts/build-private-release.mjs",
    "set-credentials": "bash scripts/set-golfbox-credentials.sh",
    "test": "bun test src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
