GOLFBOX_PROVIDER=mock

# Use official only when you are ready to call GolfBox MobileHub endpoints.
GOLFBOX_API_BASE_URL=
GOLFBOX_API_TOKEN=
GOLFBOX_USERNAME=
GOLFBOX_PASSWORD=
GOLFBOX_COUNTRY=NO
GOLFBOX_APP_LANGUAGE=en
GOLFBOX_APP_VERSION=2.7.003
GOLFBOX_SAVE_TEE_TIME_TIMEOUT_MS=20000
GOLFBOX_REQUEST_TIMEOUT_MS=15000
GOLFBOX_WEB_REQUEST_TIMEOUT_MS=15000
GOLFBOX_ALLOW_UNTRUSTED_URLS=false
GOLFBOX_INCLUDE_ERROR_BODY_SNIPPETS=false

# Keep write actions disabled until you are ready to book/cancel for real.
GOLFBOX_ENABLE_WRITE_TOOLS=false
GOLFBOX_REQUIRE_CONFIRMATION=true
